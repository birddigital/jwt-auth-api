# JWT Secret Key (minimum 32 characters recommended)
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-secret-in-production-min-32-characters

# Refresh Token Secret Key (minimum 32 characters recommended)
# Generate with: openssl rand -base64 32
REFRESH_SECRET=change-this-refresh-secret-in-production-min-32-characters

# Server Port
PORT=8080

# Environment (development, staging, production)
ENVIRONMENT=development

# Log Level (debug, info, warn, error)
LOG_LEVEL=info
